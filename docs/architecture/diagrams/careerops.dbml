// CareerOps conceptual ERD
// Status: Conceptual. This is not a Django model specification.
// Scope: accepted product and architecture boundaries through the planned application workflow.

Enum membership_role {
  owner
  administrator
  coach
  member
  viewer
}

Enum observation_state {
  received
  normalizing
  normalized
  resolving
  resolved
  ambiguous
  failed
}

Enum resolution_outcome {
  matched_existing
  created_new
  ambiguous
  rejected
  ignored
}

Enum operation_status {
  pending
  processing
  completed
  failed
  cancelled
}

Enum application_status {
  preparing
  applied
  recruiter_contact
  technical_interview
  final_interview
  offer
  rejected
  withdrawn
  archived
}

Enum evidence_type {
  cv
  project
  work_experience
  education
  portfolio
  interview_note
  application
  user_note
}

Enum support_level {
  supported
  partially_supported
  unsupported
  inference
}

Table users {
  id uuid [pk]
  email varchar [not null, unique]
  is_active boolean [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Account identity. Authentication details remain an implementation concern.'
}

Table workspaces {
  id uuid [pk]
  name varchar [not null]
  created_by_user_id uuid [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Primary tenant and privacy boundary.'
}

Table workspace_memberships {
  id uuid [pk]
  workspace_id uuid [not null]
  user_id uuid [not null]
  role membership_role [not null]
  created_at timestamptz [not null]

  Indexes {
    (workspace_id, user_id) [unique]
  }
}

Table companies {
  id uuid [pk]
  workspace_id uuid [not null]
  name varchar [not null]
  normalized_name varchar [not null]
  website_url varchar
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Workspace-scoped in v1. A future shared company dimension would require explicit identity resolution and privacy rules.'
}

Table job_sources {
  id uuid [pk]
  workspace_id uuid [not null]
  name varchar [not null]
  source_type varchar [not null]
  configuration jsonb
  is_active boolean [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Credentials and source-specific configuration belong to Integrations.'
}

Table job_observations {
  id uuid [pk]
  workspace_id uuid [not null]
  source_id uuid
  submitted_by_user_id uuid
  source_identity_key varchar [not null]
  external_reference varchar
  original_url varchar
  canonicalized_url varchar
  payload_hash varchar [not null]
  raw_payload jsonb [not null]
  observed_at timestamptz
  received_at timestamptz [not null]
  state observation_state [not null]
  schema_version varchar [not null]

  Indexes {
    (workspace_id, source_id, source_identity_key, payload_hash) [unique]
    (workspace_id, payload_hash)
    (workspace_id, state, received_at)
  }

  Note: 'Immutable source evidence. Processing state may advance. Raw payload size is bounded at the application boundary; oversized source material may move to object storage.'
}

Table job_normalizations {
  id uuid [pk]
  workspace_id uuid [not null]
  observation_id uuid [not null]
  normalizer_version varchar [not null]
  normalized_title varchar
  normalized_company_name varchar
  normalized_location varchar
  normalized_remote_policy varchar
  normalized_employment_type varchar
  salary_min decimal
  salary_max decimal
  salary_currency varchar
  description_text text
  identity_fingerprint varchar
  normalized_data jsonb [not null]
  warnings jsonb
  created_at timestamptz [not null]

  Indexes {
    (workspace_id, observation_id, normalizer_version) [unique]
    (workspace_id, identity_fingerprint)
  }

  Note: 'Versioned interpretation. Workspace is duplicated deliberately for safe tenant-scoped resolution queries.'
}

Table canonical_jobs {
  id uuid [pk]
  workspace_id uuid [not null]
  company_id uuid
  title varchar [not null]
  location varchar
  remote_policy varchar
  employment_type varchar
  salary_min decimal
  salary_max decimal
  salary_currency varchar
  description text
  published_at timestamptz
  application_deadline timestamptz
  first_seen_at timestamptz [not null]
  last_seen_at timestamptz [not null]
  archived_at timestamptz
  version int [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    (workspace_id, archived_at)
    (workspace_id, published_at)
  }

  Note: 'Mutable current understanding. Every enrichment increments version and emits a versioned event with field deltas and reason.'
}

Table job_resolutions {
  id uuid [pk]
  workspace_id uuid [not null]
  observation_id uuid [not null]
  normalization_id uuid [not null]
  canonical_job_id uuid
  outcome resolution_outcome [not null]
  algorithm_version varchar [not null]
  resolution_score decimal
  resolution_evidence jsonb [not null]
  decided_by_user_id uuid
  supersedes_resolution_id uuid
  decided_at timestamptz [not null]

  Indexes {
    (workspace_id, observation_id, decided_at)
    (workspace_id, canonical_job_id, decided_at)
  }

  Note: 'Append-only decision. Ambiguous evidence uses a versioned structure containing candidate identifiers, signal scores, threshold, and ambiguity reason. The resolution transaction coordinates observation, decision, canonical identity, audit, and outbox atomically.'
}

Table candidate_profiles {
  id uuid [pk]
  workspace_id uuid [not null]
  user_id uuid [not null]
  headline varchar
  summary text
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    (workspace_id, user_id) [unique]
  }
}

Table evidence_documents {
  id uuid [pk]
  workspace_id uuid [not null]
  candidate_profile_id uuid [not null]
  evidence_type evidence_type [not null]
  title varchar [not null]
  content text [not null]
  content_hash varchar [not null]
  source_reference varchar
  version int [not null]
  superseded_at timestamptz
  created_at timestamptz [not null]

  Indexes {
    (workspace_id, candidate_profile_id, evidence_type)
    (workspace_id, content_hash)
  }
}

Table evidence_chunks {
  id uuid [pk]
  workspace_id uuid [not null]
  document_id uuid [not null]
  sequence int [not null]
  content text [not null]
  token_count int
  chunker_version varchar [not null]
  metadata jsonb

  Indexes {
    (workspace_id, document_id, sequence) [unique]
  }

  Note: 'Workspace is duplicated so tenant filters apply before future full-text or vector retrieval.'
}

Table job_requirements {
  id uuid [pk]
  canonical_job_id uuid [not null]
  requirement_type varchar [not null]
  description text [not null]
  importance varchar [not null]
  extraction_version varchar [not null]
  created_at timestamptz [not null]

  Indexes {
    (canonical_job_id, extraction_version)
  }
}

Table opportunity_matches {
  id uuid [pk]
  workspace_id uuid [not null]
  candidate_profile_id uuid [not null]
  canonical_job_id uuid [not null]
  scoring_version varchar [not null]
  overall_score decimal [not null]
  scoring_breakdown jsonb [not null]
  created_at timestamptz [not null]
  superseded_at timestamptz

  Indexes {
    (workspace_id, candidate_profile_id, canonical_job_id, scoring_version)
  }

  Note: 'Deterministic score. RAG may explain a result but is not the scoring authority.'
}

Table match_evidence {
  id uuid [pk]
  opportunity_match_id uuid [not null]
  requirement_id uuid [not null]
  evidence_chunk_id uuid [not null]
  support_level support_level [not null]
  score decimal
  explanation text

  Indexes {
    (opportunity_match_id, requirement_id, evidence_chunk_id) [unique]
  }

  Note: 'Evidence is cited at chunk granularity. The parent document is derived through evidence_chunks.'
}

Table applications {
  id uuid [pk]
  workspace_id uuid [not null]
  candidate_profile_id uuid [not null]
  canonical_job_id uuid [not null]
  current_status application_status [not null]
  applied_at timestamptz
  salary_expectation decimal
  salary_currency varchar
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    (workspace_id, candidate_profile_id, canonical_job_id)
    (workspace_id, current_status, updated_at)
  }

  Note: 'current_status is a read optimization. It is changed only by the transition service in the same transaction that appends application_transitions.'
}

Table application_transitions {
  id uuid [pk]
  application_id uuid [not null]
  from_status application_status
  to_status application_status [not null]
  changed_by_user_id uuid [not null]
  reason text
  changed_at timestamptz [not null]

  Indexes {
    (application_id, changed_at)
  }

  Note: 'Append-only authoritative application history.'
}

Table follow_ups {
  id uuid [pk]
  application_id uuid [not null]
  assigned_to_user_id uuid [not null]
  due_at timestamptz [not null]
  completed_at timestamptz
  note text
  created_at timestamptz [not null]
}

Table operations {
  id uuid [pk]
  workspace_id uuid [not null]
  requested_by_user_id uuid
  operation_type varchar [not null]
  status operation_status [not null]
  progress int
  result_reference varchar
  error_code varchar
  error_details jsonb
  created_at timestamptz [not null]
  started_at timestamptz
  completed_at timestamptz

  Indexes {
    (workspace_id, status, created_at)
  }
}

Table idempotency_records {
  id uuid [pk]
  workspace_id uuid [not null]
  principal_reference varchar [not null]
  client_reference varchar [not null]
  idempotency_key varchar [not null]
  request_hash varchar [not null]
  response_status int
  response_envelope jsonb
  created_at timestamptz [not null]
  expires_at timestamptz [not null]

  Indexes {
    (workspace_id, principal_reference, client_reference, idempotency_key) [unique]
    (expires_at)
  }

  Note: 'Async replay stores the original 202 acceptance envelope and operation location, not mutable operation state. An expired key is treated as a new transport request; domain replay detection remains the second line of defence.'
}

Table audit_events {
  id uuid [pk]
  workspace_id uuid [not null]
  actor_user_id uuid
  action varchar [not null]
  target_type varchar [not null]
  target_id uuid
  request_id varchar
  before_state jsonb
  after_state jsonb
  metadata jsonb
  occurred_at timestamptz [not null]

  Indexes {
    (workspace_id, occurred_at)
    (target_type, target_id, occurred_at)
  }

  Note: 'Polymorphic target deliberately has no foreign key so audit history can outlive domain records.'
}

Table outbox_events {
  id uuid [pk]
  workspace_id uuid
  aggregate_type varchar [not null]
  aggregate_id uuid [not null]
  topic varchar [not null]
  event_version varchar [not null]
  payload jsonb [not null]
  occurred_at timestamptz [not null]
  published_at timestamptz
  attempt_count int [not null]

  Indexes {
    (published_at, occurred_at)
    (aggregate_type, aggregate_id, occurred_at)
  }

  Note: 'Payloads are governed by versioned event schemas. canonical_job.updated requires canonical version, resolution identifier, changed field deltas, and update reason.'
}

Ref: workspaces.created_by_user_id > users.id
Ref: workspace_memberships.workspace_id > workspaces.id
Ref: workspace_memberships.user_id > users.id

Ref: companies.workspace_id > workspaces.id
Ref: job_sources.workspace_id > workspaces.id

Ref: job_observations.workspace_id > workspaces.id
Ref: job_observations.source_id > job_sources.id
Ref: job_observations.submitted_by_user_id > users.id

Ref: job_normalizations.workspace_id > workspaces.id
Ref: job_normalizations.observation_id > job_observations.id

Ref: canonical_jobs.workspace_id > workspaces.id
Ref: canonical_jobs.company_id > companies.id

Ref: job_resolutions.workspace_id > workspaces.id
Ref: job_resolutions.observation_id > job_observations.id
Ref: job_resolutions.normalization_id > job_normalizations.id
Ref: job_resolutions.canonical_job_id > canonical_jobs.id
Ref: job_resolutions.decided_by_user_id > users.id
Ref: job_resolutions.supersedes_resolution_id > job_resolutions.id

Ref: candidate_profiles.workspace_id > workspaces.id
Ref: candidate_profiles.user_id > users.id

Ref: evidence_documents.workspace_id > workspaces.id
Ref: evidence_documents.candidate_profile_id > candidate_profiles.id
Ref: evidence_chunks.workspace_id > workspaces.id
Ref: evidence_chunks.document_id > evidence_documents.id

Ref: job_requirements.canonical_job_id > canonical_jobs.id

Ref: opportunity_matches.workspace_id > workspaces.id
Ref: opportunity_matches.candidate_profile_id > candidate_profiles.id
Ref: opportunity_matches.canonical_job_id > canonical_jobs.id

Ref: match_evidence.opportunity_match_id > opportunity_matches.id
Ref: match_evidence.requirement_id > job_requirements.id
Ref: match_evidence.evidence_chunk_id > evidence_chunks.id

Ref: applications.workspace_id > workspaces.id
Ref: applications.candidate_profile_id > candidate_profiles.id
Ref: applications.canonical_job_id > canonical_jobs.id

Ref: application_transitions.application_id > applications.id
Ref: application_transitions.changed_by_user_id > users.id

Ref: follow_ups.application_id > applications.id
Ref: follow_ups.assigned_to_user_id > users.id

Ref: operations.workspace_id > workspaces.id
Ref: operations.requested_by_user_id > users.id

Ref: idempotency_records.workspace_id > workspaces.id

Ref: audit_events.workspace_id > workspaces.id
Ref: audit_events.actor_user_id > users.id
